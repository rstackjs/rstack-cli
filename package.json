{
  "name": "rstack",
  "version": "0.0.0",
  "license": "MIT",
  "repository": "https://github.com/rstackjs/rstack",
  "bin": {
    "rs": "./bin/rs.js",
    "rstack": "./bin/rs.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "rslint && node --run format:check",
    "lint:write": "rslint --fix && node --run format",
    "test": "echo 'pass'",
    "bump": "pnpx bumpp"
  },
  "dependencies": {
    "@rsbuild/core": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@rslib/core": "catalog:",
    "@rslint/core": "catalog:",
    "@types/node": "catalog:",
    "cac": "catalog:",
    "oxfmt": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.9.0"
}
