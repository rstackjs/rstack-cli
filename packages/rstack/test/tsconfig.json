{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "emitDeclarationOnly": true,
    "composite": true,
    "rootDir": "..",
    "types": ["node", "rstack/test/globals"],
    "paths": {
      "rstack": ["../src/index.ts"],
      "rstack/test": ["../src/test.ts"],
      "#test-helpers": ["./helpers/index.ts"]
    }
  },
  "include": ["./**/*.ts", "../src"]
}
