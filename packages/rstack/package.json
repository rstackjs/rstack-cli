{
  "name": "rstack",
  "version": "0.0.0",
  "license": "MIT",
  "repository": "https://github.com/rstackjs/rstack",
  "bin": {
    "rs": "./bin/rs.js",
    "rstack": "./bin/rs.js"
  },
  "files": [
    "bin",
    "dist",
    "types"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "default": "./dist/test.js"
    },
    "./types": {
      "types": "./types/index.d.ts"
    },
    "./test/globals": {
      "types": "./types/test/globals.d.ts"
    },
    "./test/importMeta": {
      "types": "./types/test/importMeta.d.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "test": "echo 'pass'"
  },
  "dependencies": {
    "@rsbuild/core": "catalog:",
    "@rslib/core": "catalog:",
    "@rslint/core": "catalog:",
    "@rstest/core": "catalog:"
  },
  "devDependencies": {
    "@rstest/adapter-rsbuild": "catalog:",
    "@rstest/adapter-rslib": "catalog:",
    "@types/node": "catalog:",
    "lint-staged": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
