{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Type tests",
  "compilerOptions": {
    "lib": ["DOM", "ESNext"],
    "target": "ES2022",
    "types": ["node"],
    "skipLibCheck": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
